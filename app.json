{
  "expo": {
    "name": "Finexa",
    "slug": "finexa",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.finexa.app",
      "buildNumber": "11",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Utilisé pour sécuriser l'accès à votre application",
        "CFBundleLocalizations": [
          "fr",
          "en"
        ],
        "CFBundleDevelopmentRegion": "fr",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.finexa.app",
      "versionCode": 12,
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-dev-client"
    ],
    "scheme": "finexa",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e9009135-9513-4ff7-b475-139f5c837f2d"
      }
    },
    "owner": "cl3ment"
  }
}
